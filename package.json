{
  "name": "skill-markdown-c4c",
  "version": "3.5.0",
  "description": "株式会社C4C ブランドの Markdown ドキュメント生成スキル — Swiss Modern Minimal v3.5",
  "keywords": [
    "claude-code",
    "claude-skill",
    "skill",
    "markdown",
    "pdf",
    "documentation",
    "design-system",
    "swiss-modern",
    "c4c",
    "japanese",
    "vscode",
    "markdown-pdf"
  ],
  "author": "株式会社C4C",
  "license": "MIT",
  "scripts": {
    "build:zip": "node -e \"const os=require('os');const{execSync}=require('child_process');const cmd=os.platform()==='win32'?'pwsh -ExecutionPolicy Bypass -File ./scripts/build-zip.ps1':'bash ./scripts/build-zip.sh';execSync(cmd,{stdio:'inherit'})\""
  },
  "claude": {
    "skill": "skill/SKILL.md",
    "command": "skill/command.md",
    "type": "skill"
  },
  "files": [
    "skill/",
    "scripts/",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ]
}
